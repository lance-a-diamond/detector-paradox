name = "writing-quality-study"
main = "src/worker.js"
compatibility_date = "2024-09-23"
workers_dev = true

routes = [
  { pattern = "study.verovu.ai", custom_domain = true }
]

[[rules]]
type = "Text"
globs = ["**/*.html"]

[[kv_namespaces]]
binding = "STUDY_RESPONSES"
id = "e8865503306e4c11a669127c295d5e5a"

[vars]
ADMIN_PW = "<YOUR_ADMIN_PASSWORD_HERE>"
MAX_RESPONSES = "43"
# Prolific completion URL — paste the URL Prolific generates for your study here,
# format: https://app.prolific.com/submissions/complete?cc=XXXXXXXX
# Leave empty to disable the Prolific return button.
PROLIFIC_COMPLETION_URL = "https://app.prolific.com/submissions/complete?cc=<YOUR_COMPLETION_CODE>"
